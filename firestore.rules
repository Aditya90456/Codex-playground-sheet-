rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // Helper Functions
    // ---------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Schema Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['problemId', 'status']) &&
             data.problemId is string && data.problemId.size() <= 128 &&
             data.status in ['todo', 'in_progress', 'completed'];
    }

    // ---------------------------------------------------------
    // Rules
    // ---------------------------------------------------------

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // Users shouldn't be listable globally
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Only allow updating certain fields or a full valid update
        incoming().uid == existing().uid &&
        incoming().email == existing().email
      );
    }

    // Progress Collection (Subcollection of User)
    match /users/{userId}/progress/{problemId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidProgress(incoming()) && isValidId(problemId);
    }

    // Sessions Collection
    match /users/{userId}/sessions/{sessionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(sessionId);
    }

    // Forum Posts
    match /forum/posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(postId) && 
                      incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && existing().authorId == request.auth.uid;
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
    }

    // Forum Comments
    match /forum/posts/{postId}/comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(commentId) &&
                      incoming().authorId == request.auth.uid;
    }

    // Leaderboard (Public but read-only for others)
    match /leaderboard/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
  }
}
