{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user basic info, points, and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "points": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "dailyGoalMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLoginAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Progress": {
      "title": "User Progress",
      "description": "Tracks completion and notes for a specific problem",
      "type": "object",
      "properties": {
        "problemId": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in_progress", "completed"] },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "notes": { "type": "string" },
        "lastPracticedAt": { "type": "string", "format": "date-time" },
        "timeSpentMinutes": { "type": "number" },
        "pattern": { "type": "string" }
      },
      "required": ["problemId", "status"]
    },
    "StudySession": {
      "title": "Study Session",
      "description": "Logs a single study session for analytics",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "activityType": { "type": "string" }
      },
      "required": ["userId", "startTime", "durationMinutes"]
    },
    "ForumPost": {
      "title": "Forum Post",
      "description": "A post in the community forum",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "upvotes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "title", "content"]
    },
    "ForumComment": {
      "title": "Forum Comment",
      "description": "A comment on a forum post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and global state"
    },
    "/users/{userId}/progress/{problemId}": {
      "schema": "Progress",
      "description": "Problem-specific progress for a user"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "StudySession",
      "description": "History of study sessions for time tracking"
    },
    "/forum/posts/{postId}": {
      "schema": "ForumPost",
      "description": "Global forum posts"
    },
    "/forum/posts/{postId}/comments/{commentId}": {
      "schema": "ForumComment",
      "description": "Comments on a forum post"
    },
    "/leaderboard/{userId}": {
      "schema": "User",
      "description": "Public user stats for leaderboard"
    }
  }
}
